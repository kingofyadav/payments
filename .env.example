# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | staging | production
BASE_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Use an absolute path in production; :memory: for isolated test runs.
DB_PATH=./data/payments.db

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info                # trace | debug | info | warn | error | fatal | silent

# ─── Error tracking (optional) ────────────────────────────────────────────────
# Install @sentry/node, then set your project DSN. Leave blank to disable.
SENTRY_DSN=

# ─── Card vault (PCI scope — generate before deploying) ──────────────────────
# 32-byte hex string used as AES-256-GCM key for the PCI card vault.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CARD_VAULT_KEY=caffd7d0727b21a9df9127a2a7e91c091852757ba0ab256fe9dbfc07f6ab1d77

# ─── Secrets (rotate before first production deploy) ─────────────────────────
# JWT_SECRET is reserved for a future stateless-token migration.
# JWT_SECRET=change-me-at-least-32-chars

# ─── Environment isolation ────────────────────────────────────────────────────
# Use separate DB files (or separate Postgres databases) per environment:
#   DB_PATH=./data/payments-staging.db    (staging)
#   DB_PATH=./data/payments-production.db (production)

